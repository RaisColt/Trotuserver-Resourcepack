{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:custom_name",
    "cases": [
      {
        "when": "Sushi",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:using_item",
          "on_false": {
            "type": "minecraft:model",
            "model": "item/queendom/sushi"
          },
          "on_true": {
            "type": "minecraft:range_dispatch",
            "property": "minecraft:use_duration",
            "remaining": true,
            "scale": 0.048,
            "entries": [
              {
                "threshold": 0.01,
                "model": { "type": "minecraft:model", "model": "item/queendom/sushi_eat_3" }
              },
              {
                "threshold": 0.35,
                "model": { "type": "minecraft:model", "model": "item/queendom/sushi_eat_2" }
              },
              {
                "threshold": 0.57,
                "model": { "type": "minecraft:model", "model": "item/queendom/sushi_eat_1" }
              },
              {
                "threshold": 0.8,
                "model": { "type": "minecraft:model", "model": "item/queendom/sushi_eat_0" }
              },
              {
                "threshold": 1.0,
                "model": { "type": "minecraft:model", "model": "item/queendom/sushi" }
              }
            ],
            "fallback": {
              "type": "minecraft:model",
              "model": "item/queendom/sushi"
            }
        }
      }
    }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/cooked_cod"
    }
  }
}
